[4.423732, "o", "# Any2HeliosDB вҖ” migrate the Pagila sample DB (PostgreSQL) into HeliosDB-Nano.\r\n[source]\r\ndialect      = \"postgresql\"\r\nhost         = \"127.0.0.1\"\r\nport         = 45432\r\ndatabase     = \"pagila\"\r\nschema       = \"public\"\r\nuser         = \"postgres\"\r\npassword_env = \"PG_PW\"\r\n\r\n[target]                       # HeliosDB-Nano 3.60.4 over the PostgreSQL wire\r\ndriver = \"psycopg\"\r\nhost   = \"127.0.0.1\"\r\nport   = 55432\r\ndbname = \"heliosdb\"\r\nuser   = \"postgres\"            # trust auth on this disposable Nano\r\n\r\n[options]\r\noutput_dir    = \"/tmp/a2h-cast-demo/out\"\r\nparallelism   = 1\r\ndrop_existing = true\r\n"]
[4.423982, "o", "\r\n"]
