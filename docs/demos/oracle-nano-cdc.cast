[9.80647, "o", "  \u001b[33mwarn:\u001b[0m view EMP_V: Add native \u001b[1;35mNVL\u001b[0m\u001b[1m(\u001b[0m\u001b[1m)\u001b[0m support to the HeliosDB target so the migration can pass it \r\nthrough unchanged.\r\n"]
[9.806991, "o", "  \u001b[33mwarn:\u001b[0m view EMP_V: Add native \u001b[1;35mSYSDATE\u001b[0m\u001b[1m(\u001b[0m\u001b[1m)\u001b[0m support to the HeliosDB target so the migration can pass it\r\nthrough unchanged.\r\n"]
