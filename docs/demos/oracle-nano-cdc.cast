{"version": 2, "width": 100, "height": 32, "timestamp": 1782628939, "idle_time_limit": 2.0, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "Any2HeliosDB - zero-downtime CDC: Oracle HR -> HeliosDB-Nano"}
[0.008032, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.008672, "o", "\u001b[1;36m────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[1m\u001b[1;36mAny2HeliosDB\u001b[0m  —  \u001b[1mzero-downtime\u001b[0m migration via \u001b[1mCDC\u001b[0m:  Oracle HR  →  HeliosDB-Nano\r\n\u001b[1;36m────────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.310451, "o", "\u001b[0;33m# Oracle SCN-watermark CDC: bulk-load once, keep the source LIVE; INSERT/UPDATE captured by SCN, DELETE via reconcile.\u001b[0m\r\n\r\n"]
[2.311942, "o", "\u001b[0;33m# Helpers: oq = sqlplus into Oracle HR · nq = psql into HeliosDB-Nano\u001b[0m\r\n\r\n"]
[3.313918, "o", "\u001b[1;32muser01@host001\u001b[0m:\u001b[1;34m~/a2h-demo\u001b[0m$ c"]
[3.331383, "o", "a"]
[3.348839, "o", "t"]
[3.366258, "o", " "]
[3.383876, "o", "a"]
[3.401363, "o", "2"]
[3.418838, "o", "h"]
[3.436315, "o", "."]
[3.453636, "o", "t"]
[3.470933, "o", "o"]
[3.48877, "o", "m"]
[3.506406, "o", "l"]
[3.523882, "o", "\r\n"]
[3.926751, "o", "[source]\r\ndialect=\"oracle\"\r\nhost=\"127.0.0.1\"\r\nport=1521\r\nservice_name=\"XEPDB1\"\r\nuser=\"hr\"\r\npassword_env=\"ORA_PW\"\r\nschema=\"HR\"\r\n\r\n[target]\r\ndriver=\"psycopg\"\r\nhost=\"127.0.0.1\"\r\nport=55436\r\ndbname=\"heliosdb\"\r\nuser=\"postgres\"\r\n\r\n[options]\r\noutput_dir=\"/tmp/a2h-cast-oracle-cdc/out\"\r\nparallelism=1\r\ndrop_existing=true\r\n\r\n# Integer-keyed columns: map Oracle NUMBER(p,0) -> BIGINT on the target.\r\n# These are PKs / FKs (DEPT_ID, EMP_ID, ID) the CDC delete-reconcile keys on.\r\n# BIGINT is the semantically-correct target for integer keys (no fractional loss)\r\n# and keeps the delete-by-key WHERE predicate on a true integer column.\r\n[modify_type]\r\n\"hr.employees.emp_id\"   = \"bigint\"\r\n\"hr.employees.dept_id\"  = \"bigint\"\r\n\"hr.departments.dept_id\"= \"bigint\"\r\n\"hr.types_test.id\"      = \"bigint\"\r\n"]
[3.926919, "o", "\r\n"]
[5.12865, "o", "\u001b[0;33m# 1) Initial bulk load. The source stays online the whole time (zero downtime).\u001b[0m\r\n\r\n"]
