[3.980693, "o", "\r\n"]
[4.38343, "o", "[source]\r\ndialect      = \"postgresql\"\r\nhost         = \"127.0.0.1\"\r\nport         = 45432\r\ndatabase     = \"pagila_cdc_demo\"\r\nschema       = \"public\"\r\nuser         = \"postgres\"\r\npassword_env = \"PG_PW\"\r\n[target]\r\ndriver = \"psycopg\"\r\nhost   = \"127.0.0.1\"\r\nport   = 55432\r\ndbname = \"heliosdb\"\r\nuser   = \"postgres\"\r\n[options]\r\noutput_dir    = \"/tmp/a2h-cast-demo/out-cdc\"\r\nparallelism   = 1\r\ndrop_existing = true\r\n"]
[4.383591, "o", "\r\n"]
[5.585152, "o", "\u001b[0;33m# 1) Start change capture FIRST — a logical-decoding slot — so nothing is missed during/after the load.\u001b[0m\r\n\r\n"]
