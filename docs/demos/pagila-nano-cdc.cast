{"version": 2, "width": 100, "height": 32, "timestamp": 1782626535, "idle_time_limit": 2.0, "env": {"SHELL": "/bin/bash", "TERM": "xterm-256color"}, "title": "Any2HeliosDB - zero-downtime CDC: Pagila (PostgreSQL) -> HeliosDB-Nano"}
[0.007755, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.008337, "o", "\u001b[1;36m──────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[1m\u001b[1;36mAny2HeliosDB\u001b[0m  —  \u001b[1mzero-downtime\u001b[0m migration via \u001b[1mCDC\u001b[0m:  Pagila (PostgreSQL)  →  HeliosDB-Nano\r\n\u001b[1;36m──────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n\r\n"]
[1.409819, "o", "\u001b[0;33m# Log-based CDC (PostgreSQL logical decoding): bulk-load once, keep the source LIVE, stream every change.\u001b[0m\r\n\r\n"]
[2.511248, "o", "\u001b[0;33m# Helpers: sq = psql into the Pagila source · nq = psql into HeliosDB-Nano\u001b[0m\r\n\r\n"]
[3.612695, "o", "\u001b[1;32muser01@host001\u001b[0m:\u001b[1;34m~/a2h-demo\u001b[0m$ "]
[3.612747, "o", "c"]
[3.632255, "o", "a"]
