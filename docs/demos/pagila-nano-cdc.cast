[9.245398, "o", "\u001b[32mextract pagila_cdc\u001b[0m: captured \u001b[1;36m0\u001b[0m \u001b[1;35mchange\u001b[0m\u001b[1m(\u001b[0ms\u001b[1m)\u001b[0m \u001b[1m(\u001b[0mincremental since SCN \u001b[1m(\u001b[0mslot\u001b[1m)\u001b[0m\u001b[1m)\u001b[0m; \u001b[33mwatermark\u001b[0m=\u001b[1m(\u001b[0mslot\u001b[1m)\u001b[0m\r\n"]
[9.30022, "o", "\r\n"]
